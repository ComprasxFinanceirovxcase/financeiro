# Copie este arquivo para ".env" e preencha com os dados do seu projeto Supabase.
# (Projeto Supabase -> Project Settings -> API)
#
# IMPORTANTE: o arquivo ".env" NÃO vai para o GitHub (está no .gitignore).
# NUNCA coloque aqui a "service_role key" — só a "anon public key".

VITE_SUPABASE_URL=https://SEU-PROJETO.supabase.co
VITE_SUPABASE_ANON_KEY=sua-anon-public-key-aqui
